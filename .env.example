# Telegram bot token (@BotFather)
CONTENT_BOT_TOKEN=your_bot_token_here

# Admin Telegram IDs (1–2, comma-separated). Get ID from @userinfobot
ADMIN_TELEGRAM_IDS=123456789

# Target channel username without @
CHANNEL_USERNAME=itsamatchchannel

# Optional: OpenAI API key for AI features
OPENAI_API_KEY=

# Optional: main bot username for CTA text (without @)
MAIN_BOT_USERNAME=

# SQLite database path (default ./data/content_bot.db locally)
DATABASE_PATH=./data/content_bot.db

# Backup directory
BACKUP_DIR=./data/backups

# Timezone for scheduling (default Europe/Warsaw)
TIMEZONE=Europe/Warsaw
