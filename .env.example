# Telegram bot token (@BotFather)
CONTENT_BOT_TOKEN=your_bot_token_here

# Admin Telegram IDs (1–2, comma-separated). Get ID from @userinfobot
ADMIN_TELEGRAM_IDS=123456789

# Target channel username without @
CHANNEL_USERNAME=itsamatchchannel

# Optional: OpenAI API key for AI features
OPENAI_API_KEY=

# Optional: main bot username for CTA text (without @)
MAIN_BOT_USERNAME=

# SQLite database path (default ./data/content_bot.db locally)
DATABASE_PATH=./data/content_bot.db

# Backup directory
BACKUP_DIR=./data/backups

# Timezone for scheduling (default Europe/Warsaw)
TIMEZONE=Europe/Warsaw

# Optional: YouTube Data API key for YouTube discovery sources
YOUTUBE_API_KEY=

# Content discovery settings
DISCOVERY_ENABLED=true
DISCOVERY_INTERVAL_MINUTES=360
DISCOVERY_MAX_ITEMS_PER_SOURCE=5
DISCOVERY_LOOKBACK_HOURS=168
DISCOVERY_MIN_SCORE=0
DISCOVERY_AUTO_CREATE_CANDIDATES=true

# YouTube RU targeting
YOUTUBE_REGION_CODE=RU
YOUTUBE_RELEVANCE_LANGUAGE=ru
YOUTUBE_SHORTS_MAX_SECONDS=90
YOUTUBE_REJECT_OVER_SECONDS=180

# Language & quality filters
DISCOVERY_ALLOWED_LANGUAGES=ru
DISCOVERY_REJECT_FOREIGN_LANGUAGE=true
DISCOVERY_MIN_QUALITY_SCORE=6
DISCOVERY_CREATE_LOW_SCORE=false

# Reddit API (optional, for reddit_subreddit sources)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ItsAMatchContentBot/3.0
REDDIT_MAX_POSTS_PER_SOURCE=5
REDDIT_ALLOWED_SUBREDDITS=dating,dating_advice,relationships,relationship_advice,Tinder,Bumble,OnlineDating,relationshipmemes

# Daily content pack (v4)
DAILY_PACK_ENABLED=true
DAILY_PACK_TIME=10:00
DAILY_PACK_TIMEZONE=Europe/Warsaw
DAILY_PACK_VIDEO_TARGET=5
DAILY_PACK_MEME_TARGET=5
DAILY_PACK_ARTICLE_TARGET=5
DAILY_PACK_POLL_TARGET=5
DAILY_PACK_IDEA_TARGET=5
DAILY_PACK_MAX_TOTAL=30
DAILY_SCHEDULE_SLOTS=11:00,13:30,16:00,18:30,21:00
DAILY_AUTO_DISCOVERY_LOOKBACK_HOURS=48
DAILY_PACK_NOTIFY_ADMINS=true
